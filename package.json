{
  "name": "metafabrika-voice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check:agent-readability": "node scripts/check-agent-readability.mjs",
    "check:docs-sync": "node scripts/check-docs-sync.mjs",
    "check:all": "npm run check:agent-readability && npm run check:docs-sync && npm run lint && npm run format:check && npm run build && npm test && npm run test:smoke",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "RUN_SMOKE_TESTS=1 vitest run test/smoke.integration.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.2.1",
    "dotenv": "^17.2.2",
    "fastify": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-glob": "^3.3.3",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
